rules_version = '2';

// BDI University — Firestore security rules.
//
// Access model (mirrors index.html):
//  - Only @bdico.com accounts can read/write anything; anyone else gets nothing.
//  - Verification is enforced by the app's "Confirm your email" screen, NOT here,
//    because the email_verified flag in a user's token is cached and lags behind
//    real verification — gating reads on it locks out users who have verified.
//  - Signed-in BDI users share some docs (bracket, app config) read-only.
//  - Accounting + Insurance are private to access lists kept in shared/appConfig
//    (acctAccessList/acctManagers, uspsAccessList/uspsManagers); only the admin edits the lists.
//  - acctInsManagers is a distinct role that reaches the insurance log only (not requisitions).
//  - Per-user data under users/{uid} is private to that user.
//
// IMPORTANT: match blocks are OR-combined, so the sensitive shared docs are
// listed explicitly and there is deliberately NO catch-all `match /shared/{doc}`
// rule — adding one would re-grant read to everyone and defeat the locks.

service cloud.firestore {
  match /databases/{database}/documents {

    function emailLc() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }
    // Only BDI employees (an @bdico.com email, end-anchored so lookalikes fail).
    function isBdi() {
      return emailLc().matches('^[^@]+@bdico[.]com$');
    }
    // A signed-in BDI employee — the baseline for any access.
    function signedIn() {
      return request.auth != null && isBdi();
    }
    // The app treats this address as the admin (ADMINS in index.html).
    function isAdmin() {
      return emailLc() == "dgonzalez@bdico.com";
    }
    // Access lists are stored as lowercased emails on shared/appConfig.
    function cfg() {
      return exists(/databases/$(database)/documents/shared/appConfig)
        ? get(/databases/$(database)/documents/shared/appConfig).data
        : {};
    }
    // `d` is the appConfig data map, passed in so cfg() is fetched at most once per list.
    function listHas(d, field) {
      return field in d && d[field] is list && d[field].hasAny([emailLc()]);
    }
    function acctAllowed() {
      return isAdmin() || listHas(cfg(), "acctAccessList") || listHas(cfg(), "acctManagers");
    }
    // Insurance-tab managers are a distinct role: they reach the insurance log
    // (shared/insurance) but NOT the requisitions workbook (shared/accounting).
    function insAllowed() {
      return acctAllowed() || listHas(cfg(), "acctInsManagers");
    }
    function uspsAllowed() {
      return isAdmin() || listHas(cfg(), "uspsAccessList") || listHas(cfg(), "uspsManagers");
    }

    // Shared app config (tab visibility + access lists). Everyone signed in may
    // read it; only the admin may change it — the access lists live here, so a
    // non-admin must never be able to grant themselves access.
    match /shared/appConfig {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Accounting workbook (monthly requisitions & PM billings):
    // visible AND editable ONLY to people with Accounting access.
    match /shared/accounting {
      allow read, write: if acctAllowed();
    }

    // Subcontractor insurance tracking — Accounting access OR the distinct
    // insurance-manager role (acctInsManagers). Requisitions stay separate.
    // (shared/insuranceLog is written only by the cron via the service account,
    //  which bypasses rules, so it is intentionally NOT readable by clients.)
    match /shared/insurance {
      allow read, write: if insAllowed();
    }

    // USPS shared job list: only people with USPS access.
    match /shared/usps {
      allow read, write: if uspsAllowed();
    }

    // World Cup bracket fixtures/results: everyone signed in reads the board;
    // only the admin writes scores/locks (and the admin's live-feed auto-sync).
    match /shared/bracket {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Bracket picks: everyone signed in can read the leaderboard; each person
    // may only create or change their own pick document.
    match /bracketPicks/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Per-user private data and any subcollections (e.g. users/{uid}/auto/queue).
    match /users/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Outlook OAuth tokens: strictly per-user.
    match /outlookTokens/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
